{
  "project": "MP6519 Brake Disk Control",
  "version": "1.0.0",
  "design_status": "Final Schematic Design",
  "hardware": {
    "mcu": "RP2040",
    "drivers": [
      {
        "id": 1,
        "model": "MP6519GQ-Z",
        "description": "Brake 1 Controller"
      },
      {
        "id": 2,
        "model": "MP6519GQ-Z",
        "description": "Brake 2 Controller"
      },
      {
        "id": 3,
        "model": "MP6519GQ-Z",
        "description": "Brake 3 Controller"
      }
    ]
  },
  "pin_mapping": {
    "UART": {
      "peripheral": "UART0",
      "description": "Main Serial Print / Debug",
      "pins": {
        "TX": { "gpio": 0, "physical_pin": 2, "label": "UART0-TX" },
        "RX": { "gpio": 1, "physical_pin": 3, "label": "UART0-RX" }
      }
    },
    "I2C": {
      "peripheral": "I2C1",
      "pins": {
        "SDA": { "gpio": 2, "physical_pin": 4, "label": "I2C1-SDA" },
        "SCL": { "gpio": 3, "physical_pin": 5, "label": "I2C1-SCL" }
      }
    },
    "INDICATORS": {
      "ALERT_LED": {
        "gpio": 4,
        "physical_pin": 6,
        "label": "ALERT",
        "circuitry": "Connected to N-MOSFET Gate",
        "description": "System Alert/Status LED"
      }
    },
    "BRAKE_CHANNELS": {
      "BRAKE_1": {
        "ENABLE": { "gpio": 5, "physical_pin": 7, "label": "B1_EN", "hardware_config": "10K Pull-Down", "connection": "ENB MP6519GQ-Z" },
        "FAULT": { "gpio": 8, "physical_pin": 11, "label": "B1_FT", "hardware_config": "10K Pull-Up to 3.3V", "connection": "FT MP6519GQ-Z" },
        "MODE": { "gpio": 11, "physical_pin": 14, "label": "B1_MODE", "hardware_config": "10K Pull-Up to 3.3V", "connection": "MODE MP6519GQ-Z" }
      },
      "BRAKE_2": {
        "ENABLE": { "gpio": 6, "physical_pin": 8, "label": "B2_EN", "hardware_config": "10K Pull-Down", "connection": "ENB MP6519GQ-Z" },
        "FAULT": { "gpio": 9, "physical_pin": 12, "label": "B2_FT", "hardware_config": "10K Pull-Up to 3.3V", "connection": "FT MP6519GQ-Z" },
        "MODE": { "gpio": 12, "physical_pin": 15, "label": "B2_MODE", "hardware_config": "10K Pull-Up to 3.3V", "connection": "MODE MP6519GQ-Z" }
      },
      "BRAKE_3": {
        "ENABLE": { "gpio": 7, "physical_pin": 9, "label": "B3_EN", "hardware_config": "10K Pull-Down", "connection": "ENB MP6519GQ-Z" },
        "FAULT": { "gpio": 10, "physical_pin": 13, "label": "B3_FT", "hardware_config": "10K Pull-Up to 3.3V", "connection": "FT MP6519GQ-Z" },
        "MODE": { "gpio": 13, "physical_pin": 16, "label": "B3_MODE", "hardware_config": "10K Pull-Up to 3.3V", "connection": "MODE MP6519GQ-Z" }
      }
    }
  },
  "logic_levels": {
    "vcc": "3.3V",
    "io_standard": "LVCMOS"
  }
}
